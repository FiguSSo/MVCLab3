<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>System Zadań Domowych</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5">

    <h1 class="mb-4">Lista zadań domowych</h1>

    <div class="mb-3">
        <form action="/" method="GET" class="row g-2 align-items-center">
            <div class="col-auto">
                <select name="filterStatus" class="form-select">
                    <option value="Wszystkie">Wszystkie</option>
                    <option value="Nowe">Nowe</option>
                    <option value="W toku">W toku</option>
                    <option value="Zrobione">Zrobione</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-secondary">Filtruj</button>
            </div>
        </form>
    </div>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Opis zadania</th>
                <th>Termin</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            <% tasks.forEach(task => { %>
                <tr>
                    <td><%= task.opis %></td>
                    <td><%= task.termin %></td>
                    <td>
                        <form action="/update/<%= task.id %>" method="POST">
                            <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                                <option value="Nowe" <%= task.status === 'Nowe' ? 'selected' : '' %>>Nowe</option>
                                <option value="W toku" <%= task.status === 'W toku' ? 'selected' : '' %>>W toku</option>
                                <option value="Zrobione" <%= task.status === 'Zrobione' ? 'selected' : '' %>>Zrobione</option>
                            </select>
                        </form>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>

    <hr>

    <h2 class="mt-4">Dodaj nowe zadanie</h2>
    <form action="/add" method="POST" class="row g-3">
        <div class="col-md-4">
            <input type="text" name="opis" class="form-control" placeholder="Opis zadania" required>
        </div>
        <div class="col-md-3">
            <input type="date" name="termin" class="form-control" required>
        </div>
        <div class="col-md-2">
            <select name="status" class="form-select">
                <option value="Nowe">Nowe</option>
                <option value="W toku">W toku</option>
                <option value="Zrobione">Zrobione</option>
            </select>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary w-100">Dodaj zadanie</button>
        </div>
    </form>

</body>
</html>